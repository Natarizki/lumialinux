#!/bin/bash
CONFIG="/etc/lumia/config.lumen"
source "$CONFIG" 2>/dev/null
VERBOSE_MODE=false

run_pacman() {
  if $VERBOSE_MODE; then pacman "$@"; else pacman "$@" --noconfirm; fi
}

install_yay() {
  if ! command -v yay &>/dev/null; then
    echo "📡 Installing yay (AUR helper)..."
    pacman -S --noconfirm git base-devel
    cd /tmp
    git clone https://aur.archlinux.org/yay.git
    cd yay
    makepkg -si --noconfirm
    echo "✅ yay installed!"
  fi
}

put_package() {
  PKG="$1"
  echo "🔍 Searching '$PKG' in AUR and external sources..."
  install_yay
  yay -S --noconfirm "$PKG" && echo "✅ $PKG installed from AUR!" || {
    echo "❌ '$PKG' not found in AUR, trying Obarun..."
    if [ "$PKG" = "66" ] || [ "$PKG" = "66-tools" ]; then
      echo "📡 Installing 66 from Obarun..."
      curl -fsSL https://repo.obarun.org/obarun-keyring.gpg | pacman-key --add -
      echo "[obarun]
Server = https://repo.obarun.org/\$arch" >> /etc/pacman.conf
      pacman -Sy --noconfirm "$PKG" && echo "✅ $PKG installed!" || echo "❌ Failed."
    else
      echo "❌ '$PKG' not found in any source."
    fi
  }
}

case "$1" in
  -I)   shift; run_pacman -S "$@" ;;
  -R)   shift; run_pacman -R "$@" ;;
  -Re)  shift; run_pacman -S --needed "$@" ;;
  -P)   shift; run_pacman -Rns "$@" ;;
  -Pt)  shift; put_package "$@" ;;
  -S)   pacman -Ss "$2" ;;
  -i)   pacman -Si "$2" ;;
  -U)   run_pacman -Sy ;;
  -Uu)  run_pacman -Syu ;;
  -Ar)  run_pacman -Qdtq | run_pacman -Rs - 2>/dev/null || echo "Nothing to remove." ;;
  -F)   run_pacman -Dk ;;
  -C)   run_pacman -Sc ;;
  -St)
    echo "=== 📊 LumiaLinux System Status ==="
    df -h
    free -h
    pacman -Q | wc -l | xargs echo "📦 Packages installed:"
    ;;
  -CG)  cat "$CONFIG" ;;
  -Rl)  source "$CONFIG" && echo "✅ Config reloaded." ;;
  -v)   VERBOSE_MODE=true; shift; lumen "$@" ;;
  -H)
    echo "📦 LUMEN CLI - LumiaLinux Package Manager"
    echo ""
    echo "  -I  <pkg>     Install package"
    echo "  -R  <pkg>     Remove package"
    echo "  -Re <pkg>     Reinstall package"
    echo "  -P  <pkg>     Purge package"
    echo "  -Pt <pkg>     Install from AUR/external source"
    echo "  -S  <keyword> Search package"
    echo "  -i  <pkg>     Info package"
    echo "  -U            Update repository"
    echo "  -Uu           Full upgrade"
    echo "  -Ar           Autoremove unused deps"
    echo "  -F            Fix broken packages"
    echo "  -C            Clean cache"
    echo "  -St           System status"
    echo "  -CG           Show config"
    echo "  -Rl           Reload config"
    echo "  -v  <cmd>     Verbose mode"
    echo "  -H            Help"
    ;;
  *)    echo "❓ Unknown command. Run: lumen -H"; exit 1 ;;
esac
